# Manual API checks against a locally running TestEshopApplication (http://localhost:8080).
#
# CSRF: SecurityConfig uses .csrf(CsrfConfigurer::spa) = stateless CookieCsrfTokenRepository
# (double-submit). The server trusts the XSRF-TOKEN cookie as source of truth and only checks
# that the X-XSRF-TOKEN header equals it. So we pick our own token and send it in BOTH places
# on every state-changing request — each request is self-contained, run them in any order.
# This is NOT a CSRF bypass: a cross-origin attacker can neither read our cookie nor set a
# custom header, so the real defence still holds.
#
# Session cookie is SESSION (Spring Session / Redis), not the servlet container's JSESSIONID.

@host = http://localhost:8080
@xsrf = local-test-token

### 1. Login — captures the session cookie into {{session}}
POST {{host}}/api/auth/login
Content-Type: application/json
Cookie: XSRF-TOKEN={{xsrf}}
X-XSRF-TOKEN: {{xsrf}}

{
  "username": "alice",
  "password": "alicepass"
}

> {%
const cookie = response.headers.valuesOf("Set-Cookie").find(v => v.startsWith("SESSION="));
if (cookie) {
    client.global.set("session", cookie.split(";")[0].replace("SESSION=", ""));
} else {
    client.log("Login failed — no SESSION cookie returned (check credentials)");
}
%}

### 2. Who am I
GET {{host}}/api/auth/me
Cookie: SESSION={{session}}

### 3. Browse products — captures first product reference into {{productRef}}
GET {{host}}/api/products?page=0&size=5
Cookie: SESSION={{session}}

> {%
client.global.set("productRef", response.body.products[0].reference);
%}

### 4. Browse products with search
GET {{host}}/api/products?search=keyboard&page=0&size=10
Cookie: SESSION={{session}}

### 5. View cart
GET {{host}}/api/cart
Cookie: SESSION={{session}}

### 6. Add item to cart
POST {{host}}/api/cart/items
Content-Type: application/json
Cookie: SESSION={{session}}; XSRF-TOKEN={{xsrf}}
X-XSRF-TOKEN: {{xsrf}}

{
  "productReference": "{{productRef}}",
  "quantity": 2
}

### 7. Update item quantity
PATCH {{host}}/api/cart/items/{{productRef}}
Content-Type: application/json
Cookie: SESSION={{session}}; XSRF-TOKEN={{xsrf}}
X-XSRF-TOKEN: {{xsrf}}

{
  "quantity": 5
}

### 8. Remove item from cart
DELETE {{host}}/api/cart/items/{{productRef}}
Cookie: SESSION={{session}}; XSRF-TOKEN={{xsrf}}
X-XSRF-TOKEN: {{xsrf}}

### 9. Unauthenticated cart — expect 401 (explicit invalid session)
GET {{host}}/api/cart
Cookie: SESSION=invalid

### 10. Submit order — price locked, persisted as a PENDING order
POST {{host}}/api/order/submit
Content-Type: application/json
Cookie: SESSION={{session}}; XSRF-TOKEN={{xsrf}}
X-XSRF-TOKEN: {{xsrf}}

{
  "street": "123 Main St",
  "city": "Athens",
  "postalCode": "10432",
  "country": "Greece"
}

### 11. Confirm order — sends email to admin, clears cart
POST {{host}}/api/order/confirm
Cookie: SESSION={{session}}; XSRF-TOKEN={{xsrf}}
X-XSRF-TOKEN: {{xsrf}}

### 12. Submit with CR/LF injection attempt — expect 400
POST {{host}}/api/order/submit
Content-Type: application/json
Cookie: SESSION={{session}}; XSRF-TOKEN={{xsrf}}
X-XSRF-TOKEN: {{xsrf}}

{
  "street": "123 Main St\r\nBcc: evil@example.com",
  "city": "Athens",
  "postalCode": "10432",
  "country": "Greece"
}

### 13. POST without CSRF token — expect 403 (CSRF defence)
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "username": "alice",
  "password": "alicepass"
}

### 14. Login throttle — run this >10x with wrong password to trigger 429 (LoginRateLimiter)
POST {{host}}/api/auth/login
Content-Type: application/json
Cookie: XSRF-TOKEN={{xsrf}}
X-XSRF-TOKEN: {{xsrf}}

{
  "username": "alice",
  "password": "wrongpass"
}
