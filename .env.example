DB_NAME=eshop
DB_USER=eshop
DB_PASSWORD=
SHOP_ADMIN_EMAIL=admin@example.com

# Redis AUTH — session store + login rate-limit counters live here
REDIS_PASSWORD=

# Dev UI tools (docker-compose.dev.yml only — `make dev`)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=

# Mail — local dev defaults to Mailpit; no changes needed for `make up`.
# For `make prod` (real email via the Spring 'prod' profile) fill these in.
# Gmail needs 2-Step Verification ON and a 16-char App Password (NOT your account password):
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=youraddress@gmail.com
# MAIL_PASSWORD=your-16-char-app-password
# The prod profile already forces SMTP auth + STARTTLS, so MAIL_SMTP_AUTH / MAIL_STARTTLS
# are optional there (set them only for a non-prod run that still needs real mail).
